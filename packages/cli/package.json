    "bundle": "node scripts/bundle.mjs",
    "dev": "tsc --watch --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/platform-ws": "^11.0.0",
    "@nestjs/websockets": "^11.0.0",
    "commander": "^13.0.0",
    "drizzle-orm": "^0.45.1",
    "express": "^4.21.0",
    "open": "^10.1.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sql.js": "^1.14.0",
    "ssh2": "^1.16.0",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "ssh",
    "server",
    "terminal",
    "sftp",
