{
  "name": "stacklane",
  "version": "0.1.0",
  "description": "Browser-based OS-like UI for managing remote servers via SSH",
  "author": {
    "name": "Satyam Lohiya",
    "url": "https://github.com/betaversionio"
  },
  "homepage": "https://github.com/betaversionio/stacklane#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/betaversionio/stacklane.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/betaversionio/stacklane/issues"
  },
  "license": "MIT",
  "type": "module",
  "bin": {
    "stacklane": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "scripts": {
